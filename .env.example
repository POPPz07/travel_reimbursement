OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
LLM_PROVIDER=groq

# ==========================================
# DYNAMIC MULTI-PROVIDER FALLBACK SYSTEM
# ==========================================
# To use this system, rename this file to `.env`.
# 
# 1. Provide API keys for any providers you wish to use.
# 2. Set `LLM_PROVIDER` to your primary choice (`groq`, `openai`, or `gemini`).
# 
# The system is designed for Enterprise Reliability. It will automatically initialize 
# your chosen `LLM_PROVIDER` as the primary reasoning engine. 
# 
# If your primary engine goes down or hits a Rate Limit (HTTP 429), the LangGraph 
# agent will automatically intercept the failure and transparently fail-over to the 
# remaining API keys provided below, chaining them together using LangChain's native 
# `.with_fallbacks()` method.
# ==========================================
